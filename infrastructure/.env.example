# =============================================================================
# Pensum Cloud — Variables de entorno para Docker Compose
# Copiar a infrastructure/.env y completar los valores
# =============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pensum_cloud
POSTGRES_PORT=5432

# ── PgAdmin (perfil: tools) ─────────────────────────────────────────────────
PGADMIN_EMAIL=admin@pensum.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Puertos de los servicios ─────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=5173     # dev: 5173 (Vite) | prod: 80 (nginx)
DEBUG_PORT=9229        # Node.js inspector (solo dev)
