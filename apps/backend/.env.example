# =============================================================================
# Backend — Plantilla de variables de entorno
# Copiar a apps/backend/.env y ajustar los valores
#
# Modo A (local): backend en host, postgres en Docker → localhost:5432
# Modo B (Docker): docker-compose.override.yml sobreescribe DATABASE_URL
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Database ─────────────────────────────────────────────────────────────────
# Modo A — backend corriendo en el host:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pensum_cloud?schema=public"

# Modo B — si corres el backend manualmente apuntando al container:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pensum_cloud?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────────────
# ⚠️  En producción usar valores aleatorios de 64+ caracteres
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRATION=7d
