# =============================================================================
# Frontend — Plantilla de variables de entorno
# Copiar a apps/frontend/.env y ajustar si es necesario
#
# En desarrollo local (Modo A y B), Vite hace proxy automático:
#   /api/* → http://localhost:3000
# Por eso VITE_API_BASE_URL generalmente NO es necesaria en local.
# =============================================================================

# Descomenta solo si el backend NO está en localhost:3000
# VITE_API_BASE_URL=http://localhost:3000
